# Default to LF line endings, auto-detect text vs binary
* text=auto eol=lf

# Always LF for these — they break with CRLF
*.gd text eol=lf
*.gdshader text eol=lf
*.tscn text eol=lf
*.tres text eol=lf
*.cfg text eol=lf
*.toml text eol=lf
*.py text eol=lf
*.jsx text eol=lf
*.json text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# Binary
*.png binary
*.jpg binary
*.jpeg binary
*.tga binary
*.webp binary
*.psd binary
*.psb binary
*.kra binary
*.blend binary

# Git LFS — only for the examples folder, to keep the repo light
examples/**/*.psd  filter=lfs diff=lfs merge=lfs -text
examples/**/*.psb  filter=lfs diff=lfs merge=lfs -text
examples/**/*.kra  filter=lfs diff=lfs merge=lfs -text
examples/**/*.blend filter=lfs diff=lfs merge=lfs -text
examples/**/*.png  filter=lfs diff=lfs merge=lfs -text
examples/**/*.jpg  filter=lfs diff=lfs merge=lfs -text
examples/**/*.jpeg filter=lfs diff=lfs merge=lfs -text
examples/**/*.tga  filter=lfs diff=lfs merge=lfs -text
examples/**/*.webp filter=lfs diff=lfs merge=lfs -text

# GitHub linguist hints
# Photoshop ExtendScript is ECMAScript ~3 with the Photoshop DOM, not modern
# JavaScript. Marking the exporter directory non-detectable keeps CodeQL's
# JavaScript analyzer from choking on `#target photoshop` and similar.
photoshop-exporter/**/*.jsx linguist-language=Text linguist-detectable=false
*.jsx linguist-language=JavaScript
schemas/*.json linguist-detectable=false
