{
  "version": "0.2",
  "language": "pt-BR,en",
  "ignorePaths": [
    "**/pnpm-lock.yaml",
    "**/uv.lock",
    "**/package-lock.json",
    "**/*.uid",
    "PROBLEMS",
    "PROBLEMS.md",
    "specs/backlog-bugs-found.md",
    "specs/backlog-manual-testing.md",
    "specs/backlog-ui-feedback.md"
  ],
  "dictionaries": [
    "developer-terms",
    "names",
    "project-terms",
    "css",
    "docker",
    "fonts",
    "html",
    "javascript",
    "json",
    "lorem",
    "portuguese",
    "pt-br",
    "tsx",
    "typescript"
  ],
  "languageId": "*",
  "caseSensitive": false,
  "dictionaryDefinitions": [
    {
      "name": "developer-terms",
      "path": "./.cspell/developer-terms.txt",
      "addWords": true
    },
    {
      "name": "names",
      "path": "./.cspell/names.txt",
      "addWords": true
    },
    {
      "name": "project-terms",
      "path": "./.cspell/project-terms.txt",
      "addWords": true
    }
  ],
  "words": [],
  "ignoreWords": []
}
