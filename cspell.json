{
  "version": "0.2",
  "language": "pt-BR,en",
  "import": [
    "@cspell/dict-pt-br/cspell-ext.json"
  ],
  "ignorePaths": [],
  "dictionaries": [
    "developer-terms",
    "names",
    "project-terms",
    "css",
    "docker",
    "fonts",
    "html",
    "javascript",
    "json",
    "lorem",
    "portuguese",
    "pt-br",
    "tsx",
    "typescript"
  ],
  "languageId": "*",
  "caseSensitive": false,
  "dictionaryDefinitions": [
    {
      "name": "developer-terms",
      "path": "./.cspell/developer-terms.txt",
      "addWords": true
    },
    {
      "name": "names",
      "path": "./.cspell/names.txt",
      "addWords": true
    },
    {
      "name": "project-terms",
      "path": "./.cspell/project-terms.txt",
      "addWords": true
    }
  ],
  "words": [],
  "ignoreWords": []
}
