{
    "godotTools.editorPath.godot4": "e:\\godot\\godot.exe",
    "files.associations": {
        "*.jsx": "javascriptreact",
        "*.tsx": "typescriptreact",
        "LICENSE": "plaintext",
        ".gdlintrc": "yaml",
        "pyrightconfig.json": "jsonc"
    },
    "[javascriptreact]": {
        "editor.tabSize": 4
    },
    "[typescriptreact]": {
        "editor.tabSize": 4
    },
    "python.analysis.diagnosticMode": "openFilesOnly",
    "sonarlint.rules": {
        "python:S101": {
            "level": "off"
        },
        // Redundant single-member type aliases live only in the
        // json-schema-to-typescript GENERATED bindings (schema_bindings/);
        // they cannot be hand-edited (regen overwrites) and tsc gates the
        // shapes already.
        "typescript:S6564": {
            "level": "off"
        },
        // The raw useState setter is deliberately named `set<X>State` to
        // avoid clashing with the public memoised `set<X>` wrapper the hook
        // returns; the rule's name-match heuristic misreads the pattern.
        "typescript:S6754": {
            "level": "off"
        },
        // Cognitive-complexity threshold fires on the automesh geometry /
        // tag-parser algorithms whose branching is inherent to the domain;
        // splitting purely to hit the metric harms readability.
        "python:S3776": {
            "level": "off"
        },
        "typescript:S3776": {
            "level": "off"
        },
        // The automesh + polygon builders genuinely carry many geometry
        // parameters; an options-bag rewrite is tracked separately and not
        // a per-call fix.
        "python:S107": {
            "level": "off"
        },
        "typescript:S107": {
            "level": "off"
        },
        // `list(context.selected_objects)` is an intentional snapshot taken
        // before the loop mutates selection via select_set(); the rule
        // misreads Blender's selection semantics.
        "python:S7504": {
            "level": "off"
        },
        // Panel text colours come from the Adobe Spectrum theme tokens; the
        // contrast is theme-controlled, not a per-rule literal to tune.
        "css:S7924": {
            "level": "off"
        },
        // The panel affordances are Spectrum-styled clickable rows; a native
        // <button> swap fights the Spectrum layout. a11y is handled via the
        // explicit role + key handlers already present.
        "typescript:S6819": {
            "level": "off"
        },
        // The flagged params (`outer`, `inner_loops`, `material`, `mirror_x`)
        // are intentional uniform-signature / parallel-pair parameters: the
        // automesh stage dispatch and the paint-preset build/apply pair call
        // these helpers through a shared signature even when one branch does
        // not consume every input. Removing them breaks the uniform call.
        "python:S1172": {
            "level": "off"
        },
        // `dataclasses.replace()` is typed as returning `DataclassInstance`;
        // mypy (the gate) accepts the `PaintPresetSnapshot` return, so this is
        // a SonarLint type-inference gap, not a real mismatch.
        "python:S5886": {
            "level": "off"
        },
        // `tseslint.config(...)`'s variadic signature is flagged deprecated in
        // the ESLint flat-config file, which is a build config (not gated by
        // the `eslint src` run); the upstream API swap is tracked with the
        // typescript-eslint bump.
        "javascript:S1874": {
            "level": "off"
        }
    },
    "sonarlint.analysisExcludesPattern": "**/AppData/**,**/site-packages/**,**/Lib/**,**/pythoncore-*/**,**/.venv/**,**/node_modules/**,**/schema_bindings/**,PROBLEMS,PROBLEMS.md",
    "markdown.validate.ignoredLinks": [
        "../../examples/dummy/Dummy.tscn"
    ],
    // Shorthand value ranges in the bilingual dev logs (`[~]`, `[0..1]`,
    // `[-pi, pi]`) parse as shortcut reference links with no definition; the
    // project uses inline links, so reference-link validation only ever fires
    // false positives.
    "markdown.validate.referenceLinks.enabled": "ignore"
}
