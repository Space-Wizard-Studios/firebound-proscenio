{
  "id": "proscenio",
  "name": "Proscenio",
  "version": "0.1.0",
  "main": "index.html",
  "manifestVersion": 5,
  "host": {
    "app": "PS",
    "minVersion": "25.0"
  },
  "requiredPermissions": {
    "allowCodeGenerationFromStrings": true,
    "localFileSystem": "fullAccess"
  },
  "entrypoints": [
    {
      "type": "panel",
      "id": "proscenioExporter",
      "label": {
        "default": "Proscenio Exporter"
      },
      "minimumSize": { "width": 260, "height": 240 },
      "maximumSize": { "width": 2000, "height": 2000 },
      "preferredDockedSize": { "width": 280, "height": 360 },
      "preferredFloatingSize": { "width": 280, "height": 360 },
      "icons": [
        {
          "width": 32,
          "height": 32,
          "path": "icons/icon_D.png",
          "scale": [1, 2],
          "theme": ["dark", "darkest"],
          "species": ["generic"]
        },
        {
          "width": 32,
          "height": 32,
          "path": "icons/icon_N.png",
          "scale": [1, 2],
          "theme": ["lightest", "light"],
          "species": ["generic"]
        }
      ]
    },
    {
      "type": "panel",
      "id": "proscenioDebug",
      "label": {
        "default": "Proscenio Debug"
      },
      "minimumSize": { "width": 320, "height": 280 },
      "maximumSize": { "width": 2000, "height": 2000 },
      "preferredDockedSize": { "width": 380, "height": 520 },
      "preferredFloatingSize": { "width": 420, "height": 600 },
      "icons": [
        {
          "width": 32,
          "height": 32,
          "path": "icons/icon_D.png",
          "scale": [1, 2],
          "theme": ["dark", "darkest"],
          "species": ["generic"]
        },
        {
          "width": 32,
          "height": 32,
          "path": "icons/icon_N.png",
          "scale": [1, 2],
          "theme": ["lightest", "light"],
          "species": ["generic"]
        }
      ]
    },
    {
      "type": "panel",
      "id": "proscenioTags",
      "label": {
        "default": "Proscenio Tags"
      },
      "minimumSize": { "width": 320, "height": 280 },
      "maximumSize": { "width": 2000, "height": 2000 },
      "preferredDockedSize": { "width": 380, "height": 600 },
      "preferredFloatingSize": { "width": 420, "height": 680 },
      "icons": [
        {
          "width": 32,
          "height": 32,
          "path": "icons/icon_D.png",
          "scale": [1, 2],
          "theme": ["dark", "darkest"],
          "species": ["generic"]
        },
        {
          "width": 32,
          "height": 32,
          "path": "icons/icon_N.png",
          "scale": [1, 2],
          "theme": ["lightest", "light"],
          "species": ["generic"]
        }
      ]
    }
  ],
  "icons": [
    {
      "width": 32,
      "height": 32,
      "path": "icons/icon_D.png",
      "scale": [1, 2],
      "theme": ["dark", "darkest"],
      "species": ["generic"]
    },
    {
      "width": 32,
      "height": 32,
      "path": "icons/icon_N.png",
      "scale": [1, 2],
      "theme": ["lightest", "light"],
      "species": ["generic"]
    }
  ]
}
