{
    "include": [
        "apps/blender/exporters",
        "apps/blender/importers",
        "apps/blender/core",
        "apps/blender/operators",
        "apps/blender/panels",
        "apps/blender/properties",
        "apps/blender/tests",
        "packages/codegen/src",
        "packages/models/src",
        "packages/validator/src",
        "scripts",
        "tests"
    ],
    "exclude": [
        "**/.*",
        "**/__pycache__",
        "**/node_modules",
        "**/.venv",
        "apps/blender/tests/fixtures",
        "apps/blender/tests/operators",
        "apps/blender/tests/run_operator_tests.py",
        "tests/skinning",
        "tests/automesh",
        "tests/codegen"
    ],
    "extraPaths": [
        "apps/blender",
        "packages/models/src",
        "packages/codegen/src",
        "packages/validator/src"
    ],
    "venvPath": ".",
    "venv": ".venv",
    "pythonVersion": "3.13",
    "typeCheckingMode": "standard",
    "useLibraryCodeForTypes": true,
    "reportMissingImports": "none",
    "reportMissingModuleSource": "none",
    "reportAttributeAccessIssue": "warning",
    "reportOptionalMemberAccess": "warning",
    "reportPossiblyUnboundVariable": "warning",
    "reportArgumentType": "warning",
    "executionEnvironments": [
        {
            "//": "Tier-2 bpy-bound paths mirror mypy's ignore_errors override - Pylance keeps syntax + import checks but drops type errors so the editor problem count tracks mypy's gate.",
            "root": "apps/blender/core/bpy_helpers",
            "reportGeneralTypeIssues": "none",
            "reportOptionalMemberAccess": "none",
            "reportAttributeAccessIssue": "none",
            "reportArgumentType": "none",
            "reportPossiblyUnboundVariable": "none",
            "reportIncompatibleVariableOverride": "none",
            "reportIncompatibleMethodOverride": "none",
            "reportIndexIssue": "none",
            "reportOptionalSubscript": "none",
            "reportOptionalIterable": "none",
            "reportAssignmentType": "none",
            "reportReturnType": "none"
        },
        {
            "root": "apps/blender/operators",
            "reportGeneralTypeIssues": "none",
            "reportOptionalMemberAccess": "none",
            "reportAttributeAccessIssue": "none",
            "reportArgumentType": "none",
            "reportPossiblyUnboundVariable": "none",
            "reportIncompatibleVariableOverride": "none",
            "reportIncompatibleMethodOverride": "none",
            "reportIndexIssue": "none",
            "reportOptionalSubscript": "none",
            "reportOptionalIterable": "none",
            "reportAssignmentType": "none",
            "reportReturnType": "none"
        },
        {
            "root": "apps/blender/panels",
            "reportGeneralTypeIssues": "none",
            "reportOptionalMemberAccess": "none",
            "reportAttributeAccessIssue": "none",
            "reportArgumentType": "none",
            "reportPossiblyUnboundVariable": "none",
            "reportIncompatibleVariableOverride": "none",
            "reportIncompatibleMethodOverride": "none",
            "reportIndexIssue": "none",
            "reportOptionalSubscript": "none",
            "reportOptionalIterable": "none",
            "reportAssignmentType": "none",
            "reportReturnType": "none"
        },
        {
            "root": "apps/blender/properties",
            "reportGeneralTypeIssues": "none",
            "reportOptionalMemberAccess": "none",
            "reportAttributeAccessIssue": "none",
            "reportArgumentType": "none",
            "reportPossiblyUnboundVariable": "none",
            "reportIncompatibleVariableOverride": "none",
            "reportIncompatibleMethodOverride": "none",
            "reportIndexIssue": "none",
            "reportOptionalSubscript": "none",
            "reportOptionalIterable": "none",
            "reportAssignmentType": "none",
            "reportReturnType": "none"
        },
        {
            "//": "packages/validator tier-2: addon_loader + coverage + measurement live at bpy.data / bpy.ops boundary; mypy ignore_errors override covers them so Pylance follows suit.",
            "root": "packages/validator/src/proscenio_validator",
            "reportIndexIssue": "none",
            "reportAttributeAccessIssue": "none",
            "reportOptionalMemberAccess": "none",
            "reportOptionalSubscript": "none",
            "reportOptionalIterable": "none",
            "reportArgumentType": "none",
            "reportAssignmentType": "none",
            "reportReturnType": "none",
            "reportGeneralTypeIssues": "none"
        },
        {
            "//": "scripts/ holds one-off Blender helpers; mypy doesn't gate them, so Pylance shouldn't either.",
            "root": "scripts",
            "reportGeneralTypeIssues": "none",
            "reportAttributeAccessIssue": "none",
            "reportOptionalMemberAccess": "none",
            "reportArgumentType": "none",
            "reportIndexIssue": "none",
            "reportPossiblyUnboundVariable": "none"
        },
        {
            "//": "Fixture + example .blend build scripts live at the bpy.data / node-tree boundary and are not gated by mypy strict; Pylance drops the same type reports so the editor count tracks the gate.",
            "root": "packages/fixtures",
            "reportGeneralTypeIssues": "none",
            "reportAttributeAccessIssue": "none",
            "reportOptionalMemberAccess": "none",
            "reportArgumentType": "none",
            "reportIndexIssue": "none",
            "reportOptionalSubscript": "none",
            "reportOptionalIterable": "none",
            "reportAssignmentType": "none",
            "reportReturnType": "none",
            "reportPossiblyUnboundVariable": "none"
        },
        {
            "root": "examples",
            "reportGeneralTypeIssues": "none",
            "reportAttributeAccessIssue": "none",
            "reportOptionalMemberAccess": "none",
            "reportArgumentType": "none",
            "reportIndexIssue": "none",
            "reportOptionalSubscript": "none",
            "reportOptionalIterable": "none",
            "reportAssignmentType": "none",
            "reportReturnType": "none",
            "reportPossiblyUnboundVariable": "none"
        },
        {
            "//": "Headless operator + props pytest layer exercises bpy ops/data and passes SimpleNamespace mocks to typed params; correctness comes from running against Blender, not the static gate.",
            "root": "apps/blender/tests",
            "reportGeneralTypeIssues": "none",
            "reportAttributeAccessIssue": "none",
            "reportOptionalMemberAccess": "none",
            "reportArgumentType": "none",
            "reportIndexIssue": "none",
            "reportOptionalSubscript": "none",
            "reportOptionalIterable": "none",
            "reportAssignmentType": "none",
            "reportReturnType": "none",
            "reportPossiblyUnboundVariable": "none"
        },
        {
            "//": "Repo-root pytest layer (skinning / automesh / codegen) passes SimpleNamespace mocks + bpy stubs to typed params; correctness comes from running the tests, not the static gate.",
            "root": "tests",
            "reportGeneralTypeIssues": "none",
            "reportArgumentType": "none",
            "reportAttributeAccessIssue": "none",
            "reportOptionalMemberAccess": "none",
            "reportOptionalSubscript": "none",
            "reportOptionalIterable": "none",
            "reportIndexIssue": "none",
            "reportAssignmentType": "none",
            "reportReturnType": "none",
            "reportPossiblyUnboundVariable": "none"
        },
        {
            "//": "writer + importers touch the bpy attribute boundary (Action.fcurves, the registered Object.proscenio PropertyGroup) that mypy treats as untyped; drop the matching reports so the editor tracks the mypy gate while structural reports stay on.",
            "root": "apps/blender/exporters",
            "reportAttributeAccessIssue": "none",
            "reportOptionalMemberAccess": "none",
            "reportArgumentType": "none"
        },
        {
            "root": "apps/blender/importers",
            "reportAttributeAccessIssue": "none",
            "reportOptionalMemberAccess": "none",
            "reportArgumentType": "none"
        }
    ]
}
