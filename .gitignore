# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.venv/
venv/
.pytest_cache/
.ruff_cache/
.mypy_cache/

# Blender
*.blend1
*.blend2
*.blend@
*.blend.bak

# Godot 4
.godot/
.import/
*.translation
export.cfg
export_presets.cfg

# Dev-only fixture copies inside the Godot dev project — canonical lives in examples/
godot-plugin/test_dummy/
godot-plugin/effect/
godot-plugin/dummy/

# Godot's import sidecars under tests/fixtures/ — regenerated locally, not source
godot-plugin/tests/fixtures/*.import

# Headless test artifacts under scripts/ — re-runnable, not source
scripts/*.out
scripts/*.log
scripts/*.out.proscenio

# Atlas packer outputs (5.1.c.2) — regenerated by the Pack Atlas operator
*.atlas.png
*.atlas.json

# Per-developer Claude Code workspace state
.claude/

# OS
.DS_Store
Thumbs.db
desktop.ini

# Editors
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
.idea/
*.swp
*.swo

# Build artifacts
dist/
build/
out/
*.zip

# Node / UXP plugin
node_modules/
package-lock.json
yarn.lock

# Local-only files
MANUAL_TESTS_PENDING.md
