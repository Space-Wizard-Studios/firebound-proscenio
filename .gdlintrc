# gdlint config — keeps GDScript typing-friendly while staying out of the
# way for cosmetics. Defaults documented at:
# https://github.com/Scony/godot-gdscript-toolkit/wiki/3.-Linter
#
# We rely on Godot's own "treat warnings as errors" setting (configured in
# `apps/godot/project.godot`) for the typing enforcement; gdlint here
# covers structural / sizing / design rules that the editor parser does not.

# Sizing — surface reviews early.
max-file-lines: 500
max-line-length: 100
function-arguments-number: 6
max-public-methods: 20
function-statements-number: 30

# Design — keep the plugin idiomatic.
duplicated-load: true
no-elif-return: true
no-else-return: true
private-method-call: true

# Disable rules that fight strict typing or our chosen style.
disable:
    - max-returns-amount
    - mixed-tabs-and-spaces
