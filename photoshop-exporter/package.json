{
  "name": "proscenio-photoshop-uxp",
  "version": "0.1.0",
  "description": "Proscenio Photoshop UXP plugin (PSD layers + manifest JSON exporter / importer)",
  "license": "GPL-3.0-or-later",
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "watch": "nodemon -w src -e ts,tsx,js,jsx,json,css,html -w webpack.config.js -x pnpm run build",
    "build": "webpack --mode development",
    "typecheck": "tsc --noEmit",
    "uxp:load": "cd dist && uxp plugin load",
    "uxp:reload": "cd dist && uxp plugin reload",
    "uxp:watch": "cd dist && nodemon --exec \"uxp plugin reload\" -e js,css,html",
    "uxp:debug": "cd dist && uxp plugin debug"
  },
  "devDependencies": {
    "@babel/core": "^7.8.7",
    "@babel/plugin-syntax-class-properties": "^7.10.4",
    "@babel/plugin-transform-object-rest-spread": "^7.24.0",
    "@babel/plugin-transform-react-jsx": "^7.8.3",
    "@babel/preset-typescript": "^7.24.0",
    "@types/react": "^16.14.0",
    "@types/react-dom": "^16.9.0",
    "babel-loader": "^8.0.6",
    "clean-webpack-plugin": "^2.0.2",
    "copy-webpack-plugin": "^5.0.3",
    "css-loader": "^6.8.1",
    "file-loader": "^5.1.0",
    "nodemon": "^2.0.7",
    "style-loader": "^1.1.3",
    "typescript": "^5.4.0",
    "webpack": "^5.88.1",
    "webpack-cli": "^5.1.4"
  },
  "dependencies": {
    "react": "^16.8.6",
    "react-dom": "^16.8.6"
  },
  "resolutions": {
    "acorn": "npm:acorn-with-stage3"
  }
}
