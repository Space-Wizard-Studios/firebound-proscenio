; Documentation-by-example wrapper scene for the Proscenio dummy fixture.
;
; This .tscn instances `dummy.proscenio` (regenerated as `dummy.scn` by the
; Godot importer on every reimport) and attaches `Dummy.gd` to the wrapper
; root. Scripts and extra nodes stay on the wrapper and survive every
; reimport — see SPEC 001 (specs/001-reimport-merge/STUDY.md).
;
; The `path="res://dummy/..."` references assume you drop `examples/dummy/`
; into your Godot project at `res://dummy/`. Adjust paths for your layout.
; UIDs regenerate the first time Godot opens the scene in your project.

[gd_scene load_steps=3 format=3]

[ext_resource type="PackedScene" path="res://dummy/dummy.proscenio" id="1_dummy"]
[ext_resource type="Script" path="res://dummy/Dummy.gd" id="2_dummy"]

[node name="Dummy" type="Node2D"]
script = ExtResource("2_dummy")

[node name="DummyCharacter" parent="." instance=ExtResource("1_dummy")]
