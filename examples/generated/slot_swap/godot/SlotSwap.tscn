; Documentation-by-example wrapper scene for the Proscenio slot_swap fixture.
;
; Minimal slot-system isolation test: a pseudo-arm swings while its
; weapon attachment swaps mid-animation (axe <-> sword). Wraps the
; imported scene so the user can attach scripts / collisions / extra
; nodes here without losing them on reimport (SPEC 001 Option A).
;
; Drop `examples/generated/slot_swap/` at `res://slot_swap/` in your Godot
; project, or adjust paths to match your layout.

[gd_scene load_steps=3 format=3]

[ext_resource type="PackedScene" path="res://slot_swap/slot_swap.proscenio" id="1_slot"]
[ext_resource type="Script" path="res://slot_swap/godot/SlotSwap.gd" id="2_slot"]

[node name="SlotSwap" type="Node2D"]
script = ExtResource("2_slot")

[node name="SlotSwapCharacter" parent="." instance=ExtResource("1_slot")]
