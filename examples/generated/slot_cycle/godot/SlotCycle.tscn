; Documentation-by-example wrapper scene for the Proscenio slot_cycle fixture.
;
; Smallest end-to-end exercise of the SPEC 004 slot system: one slot
; with three colored attachment polygons, an animation that cycles
; visibility through them. Wrapper instances the imported scene and
; lets the user attach scripts / collisions / extra nodes here without
; losing them on reimport (SPEC 001 Option A).
;
; Drop `examples/generated/slot_cycle/` at `res://slot_cycle/` in your Godot project,
; or adjust paths to match your layout.

[gd_scene load_steps=3 format=3]

[ext_resource type="PackedScene" path="res://slot_cycle/slot_cycle.proscenio" id="1_slot"]
[ext_resource type="Script" path="res://slot_cycle/godot/SlotCycle.gd" id="2_slot"]

[node name="SlotCycle" type="Node2D"]
script = ExtResource("2_slot")

[node name="SlotCycleCharacter" parent="." instance=ExtResource("1_slot")]
