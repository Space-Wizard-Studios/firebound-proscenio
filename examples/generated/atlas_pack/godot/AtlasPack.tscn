; Documentation-by-example wrapper scene for the Proscenio atlas_pack fixture.
;
; Nine flat-colored quads, each with its own texture. Workbench for the
; atlas packer (SPEC 005.1.c) -- after running Pack Atlas + Apply on the
; .blend, the importer drops a packed atlas + rewritten UVs here. Wraps
; the imported scene so the user can attach scripts / collisions / extra
; nodes here without losing them on reimport (SPEC 001 Option A).
;
; Drop `examples/generated/atlas_pack/` at `res://atlas_pack/` in your Godot
; project, or adjust paths to match your layout.

[gd_scene load_steps=3 format=3]

[ext_resource type="PackedScene" path="res://atlas_pack/atlas_pack.proscenio" id="1_atlas"]
[ext_resource type="Script" path="res://atlas_pack/godot/AtlasPack.gd" id="2_atlas"]

[node name="AtlasPack" type="Node2D"]
script = ExtResource("2_atlas")

[node name="AtlasPackCharacter" parent="." instance=ExtResource("1_atlas")]
