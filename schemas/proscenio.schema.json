{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://space-wizard-studios.github.io/proscenio/schemas/proscenio.schema.json",
  "title": "Proscenio character",
  "description": "Versioned interchange format produced by the Proscenio Blender addon and consumed by the Proscenio Godot plugin.",
  "type": "object",
  "required": ["format_version", "name", "pixels_per_unit", "skeleton", "sprites"],
  "additionalProperties": false,
  "properties": {
    "format_version": {
      "type": "integer",
      "const": 1,
      "description": "Bump on any breaking change to the shape of this document."
    },
    "name": { "type": "string", "minLength": 1 },
    "pixels_per_unit": { "type": "number", "exclusiveMinimum": 0 },
    "atlas": { "type": "string" },
    "skeleton": {
      "type": "object",
      "required": ["bones"],
      "additionalProperties": false,
      "properties": {
        "bones": {
          "type": "array",
          "items": { "$ref": "#/$defs/Bone" }
        }
      }
    },
    "sprites": {
      "type": "array",
      "items": { "$ref": "#/$defs/Sprite" }
    },
    "slots": {
      "type": "array",
      "items": { "$ref": "#/$defs/Slot" }
    },
    "animations": {
      "type": "array",
      "items": { "$ref": "#/$defs/Animation" }
    }
  },
  "$defs": {
    "Vec2": {
      "type": "array",
      "items": { "type": "number" },
      "minItems": 2,
      "maxItems": 2
    },
    "Bone": {
      "type": "object",
      "required": ["name"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "parent": { "type": ["string", "null"] },
        "position": { "$ref": "#/$defs/Vec2" },
        "rotation": { "type": "number" },
        "scale": { "$ref": "#/$defs/Vec2" },
        "length": { "type": "number", "minimum": 0 }
      }
    },
    "Rect": {
      "type": "array",
      "items": { "type": "number" },
      "minItems": 4,
      "maxItems": 4,
      "description": "[x, y, width, height] in atlas pixels."
    },
    "Sprite": {
      "oneOf": [
        { "$ref": "#/$defs/PolygonSprite" },
        { "$ref": "#/$defs/SpriteFrameSprite" }
      ]
    },
    "PolygonSprite": {
      "type": "object",
      "required": ["name", "texture_region", "polygon", "uv"],
      "additionalProperties": false,
      "description": "Cutout-style sprite rendered as a Godot Polygon2D — vertices + UV. Default sprite kind when `type` is omitted (backwards-compatible with v1 documents).",
      "properties": {
        "type": {
          "const": "polygon",
          "default": "polygon",
          "description": "Discriminator. Optional; absence means `polygon`."
        },
        "name": { "type": "string", "minLength": 1 },
        "bone": { "type": "string" },
        "texture_region": { "$ref": "#/$defs/Rect" },
        "polygon": {
          "type": "array",
          "items": { "$ref": "#/$defs/Vec2" }
        },
        "uv": {
          "type": "array",
          "items": { "$ref": "#/$defs/Vec2" }
        },
        "weights": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["bone", "values"],
            "additionalProperties": false,
            "properties": {
              "bone": { "type": "string" },
              "values": {
                "type": "array",
                "items": { "type": "number", "minimum": 0, "maximum": 1 }
              }
            }
          }
        }
      }
    },
    "SpriteFrameSprite": {
      "type": "object",
      "required": ["type", "name", "bone", "hframes", "vframes"],
      "additionalProperties": false,
      "description": "Spritesheet sprite rendered as a Godot Sprite2D — `frame` indexes into an `hframes` × `vframes` grid carved out of the atlas (or out of `texture_region` when present).",
      "properties": {
        "type": {
          "const": "sprite_frame",
          "description": "Discriminator. Required and constant."
        },
        "name": { "type": "string", "minLength": 1 },
        "bone": { "type": "string" },
        "texture_region": {
          "$ref": "#/$defs/Rect",
          "description": "Optional sub-rectangle within the atlas where the spritesheet lives. Absent → use the full atlas."
        },
        "hframes": { "type": "integer", "minimum": 1 },
        "vframes": { "type": "integer", "minimum": 1 },
        "frame": {
          "type": "integer",
          "minimum": 0,
          "default": 0,
          "description": "Initial frame index (row-major). Animation tracks override at runtime."
        },
        "offset": {
          "$ref": "#/$defs/Vec2",
          "default": [0, 0]
        },
        "centered": {
          "type": "boolean",
          "default": true
        }
      }
    },
    "Slot": {
      "type": "object",
      "required": ["name", "attachments"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "bone": { "type": "string" },
        "default": { "type": "string" },
        "attachments": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "Animation": {
      "type": "object",
      "required": ["name", "length", "tracks"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "length": { "type": "number", "exclusiveMinimum": 0 },
        "loop": { "type": "boolean" },
        "tracks": {
          "type": "array",
          "items": { "$ref": "#/$defs/Track" }
        }
      }
    },
    "Track": {
      "type": "object",
      "required": ["type", "target", "keys"],
      "additionalProperties": false,
      "properties": {
        "type": {
          "enum": ["bone_transform", "sprite_frame", "slot_attachment", "visibility"]
        },
        "target": { "type": "string", "minLength": 1 },
        "keys": {
          "type": "array",
          "items": { "$ref": "#/$defs/Key" }
        }
      }
    },
    "Key": {
      "type": "object",
      "required": ["time"],
      "additionalProperties": false,
      "properties": {
        "time": { "type": "number", "minimum": 0 },
        "interp": { "enum": ["linear", "constant"] },
        "position": { "$ref": "#/$defs/Vec2" },
        "rotation": { "type": "number" },
        "scale": { "$ref": "#/$defs/Vec2" },
        "frame": { "type": "integer", "minimum": 0 },
        "attachment": { "type": "string" },
        "visible": { "type": "boolean" }
      }
    }
  }
}
